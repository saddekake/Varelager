@page "/Customers"
@rendermode InteractiveServer
@inject HttpClient Http
@inject AuthService Auth
@using Varelager.ApiService.Data

@if (!Auth.IsLoggedIn)
{
    <p>You must log in to see this page</p>
}
else if (Auth.Type != "Admin" && Auth.Type != "Sales")
{
    <p>Access denied</p>
}
else
{
    <h3>Customers</h3>

    @* ------------------------------------------ create *@
    <input type="text" @bind="createInputFName" placeholder="Fname" />
    <input type="text" @bind="createInputLName" placeholder="Lname" />
    <input type="text" @bind="createInputPhone" placeholder="phone" />
    <input type="text" @bind="createInputEmail" placeholder="email" />
    <select @bind="createInputCountry">
        <option value=0>-- select country --</option>

        @foreach (var country in countries)
        {
            <option value=@country.Id>@country.Name</option>
        }
    </select>
    <button class="btn btn-primary" @onclick="AddToTable">add name</button>

    <br />
    <br />
    @* ------------------------------------------ update *@
    <input type="text" @bind="updateInputFName" placeholder="Fname" />
    <input type="text" @bind="updateInputLName" placeholder="Lname" />
    <input type="text" @bind="updateInputPhone" placeholder="phone" />
    <input type="text" @bind="updateInputEmail" placeholder="email" />
    <select @bind="updateInputCountry">
        <option value="">-- select country --</option>

        @foreach (var country in countries)
        {
            <option value="@country.Id">@country.Name</option>
        }
    </select>

    <br />
    <input type="number" @bind="updateId" placeholder="id of row update" />
    <br />
    <button class="btn btn-primary" @onclick="UpdateRow">update</button>

    <br />
    <br />
    @* ------------------------------------------ delete *@
    <input type="number" @bind="deleteId" placeholder="id of row delete" />
    <button class="btn btn-primary" @onclick="DeleteRow">delete</button>

    @* table *@
    <table class="table">
        <thead>
            <tr>
                <th>id</th>
                <th>fname</th>
                <th>lname</th>
                <th>phone</th>
                <th>email</th>
                <th>country</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in items)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.FName</td>
                    <td>@item.LName</td>
                    <td>@item.Phone</td>
                    <td>@item.Email</td>
                    <td>@item.Country.Name</td>
                </tr>
            }
        </tbody>
    </table>

    @code {
    private string createInputFName = "";
    private string createInputLName = "";
    private string createInputPhone = "";
    private string createInputEmail = "";
    private int createInputCountry;

    private string updateInputFName = "";
    private string updateInputLName = "";
    private string updateInputPhone = "";
    private string updateInputEmail = "";
    private int updateInputCountry;
    private int updateId;

    private int deleteId;

    private List<Customer> items = new();
    private List<Country> countries = new();

    private async Task AddToTable()
    {
        if (!string.IsNullOrWhiteSpace(createInputFName) &&
            !string.IsNullOrWhiteSpace(createInputLName) &&
            !string.IsNullOrWhiteSpace(createInputPhone) &&
            !string.IsNullOrWhiteSpace(createInputEmail) &&
            createInputCountry >0)
        {
            await Http.PostAsJsonAsync("https://localhost:7507/customers", new { 
                FName = createInputFName, 
                Lname = createInputLName, 
                Phone = createInputPhone,
                Email = createInputEmail,
                CountryId = createInputCountry }); // send post request to url with variables
        }
        createInputFName = "";
        createInputLName = "";
        createInputPhone = "";
        createInputEmail = "";
        createInputCountry = 0;

        await ReturnAllInTable();
    }
    private async Task ReturnAllInTable()
    {
        items = await Http.GetFromJsonAsync<List<Customer>>("https://localhost:7507/customers"); // sends get request to url and turns data into list
    }

    private async Task LoadCountries()
    {
        countries = await Http.GetFromJsonAsync<List<Country>>("https://localhost:7507/countries");
    }

    private async Task UpdateRow()
    {
        if (
        !string.IsNullOrWhiteSpace(updateInputFName) &&
        !string.IsNullOrWhiteSpace(updateInputLName) &&
        !string.IsNullOrWhiteSpace(updateInputPhone) &&
        !string.IsNullOrWhiteSpace(updateInputEmail) &&
        updateInputCountry >0 &&
        updateId >= 0)
        {
            await Http.PatchAsJsonAsync($"https://localhost:7507/customers/{updateId}", new { 
                FName = updateInputFName,
                LName = updateInputLName,
                Phone = updateInputPhone,
                Email = updateInputEmail,
                CountryId = updateInputCountry }); // sends patch request to url with id and input
        }
        updateInputFName = "";
        updateInputLName = "";
        updateInputPhone = "";
        updateInputEmail = "";
        updateInputCountry = 0;
        updateId = 0;

        await ReturnAllInTable();
    }
    private async Task DeleteRow()
    {
        if (deleteId >= 0)
        {
            await Http.DeleteAsync($"https://localhost:7507/customers/{deleteId}"); // sends delete request to url with id
        }
        deleteId = 0;
        await ReturnAllInTable();
    }

    protected override async Task OnInitializedAsync()
    {
        await ReturnAllInTable();
        await LoadCountries();
    }
}
}