@page "/Customers"
@rendermode InteractiveServer
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider
@using Varelager.ApiService.Data

<AuthorizeView Policy="SalesOnly">
    <NotAuthorized>
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
            Access denied
        </MudAlert>
    </NotAuthorized>
    <Authorized>
        <MudText Typo="Typo.h3">Customers</MudText>

        @* ------------------------------------------ create *@
        <MudGrid Spacing="3">
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Create Customer</MudText>

                    <MudStack Spacing="2">
                        <MudTextField T="string"
                                      @bind-Value="createInputFName"
                                      Label="First Name"
                                      Variant="Variant.Outlined" />

                        <MudTextField T="string"
                                      @bind-Value="createInputLName"
                                      Label="Last Name"
                                      Variant="Variant.Outlined" />

                        <MudTextField T="string"
                                      @bind-Value="createInputPhone"
                                      Label="Phone"
                                      Variant="Variant.Outlined" />
                        <MudTextField T="string"
                                      @bind-Value="createInputEmail"
                                      Label="Email"
                                      Variant="Variant.Outlined" />
                        <MudSelect T="int?"
                                   @bind-Value="createInputCountry"
                                   Label="Country"
                                   Variant="Variant.Outlined"
                                   Placeholder="-- Select Country --">
                            @foreach (var country in countries)
                            {
                                <MudSelectItem Value="@((int?)country.Id)">
                                    @country.Name
                                </MudSelectItem>
                            }
                        </MudSelect>

                        <MudButton Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   OnClick="AddToTable">
                            Add Customer
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudItem>
            @* ------------------------------------------ update *@
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Update Customer</MudText>

                    <MudStack Spacing="2">
                        <MudTextField T="string"
                                      @bind-Value="updateInputFName"
                                      Label="First Name"
                                      Variant="Variant.Outlined" />

                        <MudTextField T="string"
                                      @bind-Value="updateInputLName"
                                      Label="Last Name"
                                      Variant="Variant.Outlined" />

                        <MudTextField T="string"
                                      @bind-Value="updateInputPhone"
                                      Label="Phone"
                                      Variant="Variant.Outlined" />

                        <MudTextField T="string"
                                      @bind-Value="updateInputEmail"
                                      Label="Email"
                                      Variant="Variant.Outlined" />

                        <MudSelect T="int?"
                                   @bind-Value="updateInputCountry"
                                   Label="Country"
                                   Placeholder="-- Select Country --"
                                   Variant="Variant.Outlined">

                            @foreach (var country in countries)
                            {
                                <MudSelectItem Value="@((int?)country.Id)">
                                    @country.Name
                                </MudSelectItem>
                            }
                        </MudSelect>

                        <MudButton Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   OnClick="UpdateRow">
                            Update supplier
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudItem>
            @* ------------------------------------------ delete *@
            <MudItem xs="8" md="4">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Delete Customer</MudText>
                    <MudInput T="int" @bind-Value="deleteId" placeholder="ID of deleting row" />
                    <MudButton Color="Color.Primary" Variant=Variant.Filled" OnClick="DeleteRow">Delete</MudButton>
                </MudPaper>
            </MudItem>

            @* table *@
            <MudItem xs="12">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Customers Table</MudText>

                    <MudTable Items="items" Dense="true" Hover="true" Striped="true">
                        <HeaderContent>
                            <MudTh>ID</MudTh>
                            <MudTh>FName</MudTh>
                            <MudTh>LName</MudTh>
                            <MudTh>Phone</MudTh>
                            <MudTh>Email</MudTh>
                            <MudTh>Country</MudTh>
                        </HeaderContent>
                        <RowTemplate context="cus">
                            <MudTd DataLabel="ID">@cus.Id</MudTd>
                            <MudTd DataLabel="FName">@cus.FName</MudTd>
                            <MudTd DataLabel="LName">@cus.LName</MudTd>
                            <MudTd DataLabel="Phone">@cus.Phone</MudTd>
                            <MudTd DataLabel="Email">@cus.Email</MudTd>
                            <MudTd DataLabel="Country">@cus.Country.Name</MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </Authorized>
</AuthorizeView>
@code {
    private string createInputFName = "";
    private string createInputLName = "";
    private string createInputPhone = "";
    private string createInputEmail = "";
    private int? createInputCountry;

    private string updateInputFName = "";
    private string updateInputLName = "";
    private string updateInputPhone = "";
    private string updateInputEmail = "";
    private int? updateInputCountry;
    private int updateId;

    private int deleteId;

    private IEnumerable<System.Security.Claims.Claim>? claims;

    private List<Customer> items = new();
    private List<Country> countries = new();

    private async Task AddToTable()
    {
        if (!string.IsNullOrWhiteSpace(createInputFName) &&
            !string.IsNullOrWhiteSpace(createInputLName) &&
            !string.IsNullOrWhiteSpace(createInputPhone) &&
            !string.IsNullOrWhiteSpace(createInputEmail) &&
            createInputCountry > 0)
        {
            await Http.PostAsJsonAsync("https://localhost:7507/customers", new
            {
                FName = createInputFName,
                Lname = createInputLName,
                Phone = createInputPhone,
                Email = createInputEmail,
                CountryId = createInputCountry
            }); // send post request to url with variables
        }
        createInputFName = "";
        createInputLName = "";
        createInputPhone = "";
        createInputEmail = "";
        createInputCountry = 0;

        await ReturnAllInTable();
    }
    private async Task ReturnAllInTable()
    {
        items = await Http.GetFromJsonAsync<List<Customer>>("https://localhost:7507/customers"); // sends get request to url and turns data into list
    }

    private async Task LoadCountries()
    {
        countries = await Http.GetFromJsonAsync<List<Country>>("https://localhost:7507/countries");
    }

    private async Task UpdateRow()
    {
        if (
        !string.IsNullOrWhiteSpace(updateInputFName) &&
        !string.IsNullOrWhiteSpace(updateInputLName) &&
        !string.IsNullOrWhiteSpace(updateInputPhone) &&
        !string.IsNullOrWhiteSpace(updateInputEmail) &&
        updateInputCountry > 0 &&
        updateId >= 0)
        {
            await Http.PatchAsJsonAsync($"https://localhost:7507/customers/{updateId}", new
            {
                FName = updateInputFName,
                LName = updateInputLName,
                Phone = updateInputPhone,
                Email = updateInputEmail,
                CountryId = updateInputCountry
            }); // sends patch request to url with id and input
        }
        updateInputFName = "";
        updateInputLName = "";
        updateInputPhone = "";
        updateInputEmail = "";
        updateInputCountry = 0;
        updateId = 0;

        await ReturnAllInTable();
    }
    private async Task DeleteRow()
    {
        if (deleteId >= 0)
        {
            await Http.DeleteAsync($"https://localhost:7507/customers/{deleteId}"); // sends delete request to url with id
        }
        deleteId = 0;
        await ReturnAllInTable();
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        claims = user.Claims;

        await ReturnAllInTable();
        await LoadCountries();
    }
}