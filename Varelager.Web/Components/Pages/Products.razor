@page "/Products"
@rendermode InteractiveServer
@inject HttpClient Http
@using Varelager.ApiService.Data

<AuthorizeView Policy="WarehouseOnly">
    <NotAuthorized>
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
            Access denied
        </MudAlert>
    </NotAuthorized>
    <Authorized>
        <MudText Typo="Typo.h3">Products</MudText>

        @* ------------------------------------------ create *@
        <MudGrid Spacing="3">
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Create Product</MudText>

                    <MudStack Spacing="2">
                        <MudTextField T="string"
                                      @bind-Value="createInputName"
                                      Label="Name"
                                      Variant="Variant.Outlined" />

                        <MudTextField T="string"
                                      @bind-Value="createInputDescription"
                                      Label="Description"
                                      Variant="Variant.Outlined" />

                        <MudTextField T="double"
                                      @bind-Value="createInputWeight"
                                      Label="Weight"
                                      Variant="Variant.Outlined" />

                        <MudTextField T="int"
                                      @bind-Value="createInputStock"
                                      Label="Stock"
                                      Variant="Variant.Outlined" />

                        <MudSelect T="int?"
                                   @bind-Value="createInputSupplierId"
                                   Label="Supplier"
                                   Placeholder="-- Select Supplier --"
                                   Variant="Variant.Outlined">

                            @foreach (var supplier in suppliers)
                            {
                                <MudSelectItem Value="@((int?)supplier.Id)">
                                    @supplier.Name
                                </MudSelectItem>
                            }
                        </MudSelect>

                        <MudButton Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   OnClick="AddToTable">
                            Add Product
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudItem>
            @* ------------------------------------------ update *@
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Update Product</MudText>

                    <MudStack Spacing="2">
                        <MudTextField T="string"
                                      @bind-Value="updateInputName"
                                      Label="Name"
                                      Variant="Variant.Outlined" />

                        <MudTextField T="string"
                                      @bind-Value="updateInputDescription"
                                      Label="Description"
                                      Variant="Variant.Outlined" />

                        <MudTextField T="double"
                                      @bind-Value="updateInputWeight"
                                      Label="Weight"
                                      Variant="Variant.Outlined" />

                        <MudTextField T="int"
                                      @bind-Value="updateInputStock"
                                      Label="Stock"
                                      Variant="Variant.Outlined" />

                        <MudSelect T="int?"
                                   @bind-Value="updateInputSupplierId"
                                   Label="Supplier"
                                   Placeholder="-- Select Supplier --"
                                   Variant="Variant.Outlined">

                            @foreach (var supplier in suppliers)
                            {
                                <MudSelectItem Value="@((int?)supplier.Id)">
                                    @supplier.Name
                                </MudSelectItem>
                            }
                        </MudSelect>

                        <MudButton Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   OnClick="UpdateRow">
                            Update Product
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudItem>
            @* ------------------------------------------ delete *@
            <MudItem xs="8" md="4">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Delete Product</MudText>
                    <MudInput T="int" @bind-Value="deleteId" placeholder="ID of deleting row" />
                    <MudButton Color="Color.Primary" Variant=Variant.Filled" OnClick="DeleteRow">Delete</MudButton>
                </MudPaper>
            </MudItem>

            @* table *@
            <MudItem xs="12">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Products Table</MudText>

                    <MudTable Items="items" Dense="true" Hover="true" Striped="true">
                        <HeaderContent>
                            <MudTh>ID</MudTh>
                            <MudTh>Name</MudTh>
                            <MudTh>Description</MudTh>
                            <MudTh>Weight</MudTh>
                            <MudTh>Stock</MudTh>
                            <MudTh>Supplier</MudTh>
                        </HeaderContent>
                        <RowTemplate context="pro">
                            <MudTd DataLabel="ID">@pro.Id</MudTd>
                            <MudTd DataLabel="Name">@pro.Name</MudTd>
                            <MudTd DataLabel="Description">@pro.Description</MudTd>
                            <MudTd DataLabel="Weight">@pro.Weight</MudTd>
                            <MudTd DataLabel="Stock">@pro.Stock</MudTd>
                            <MudTd DataLabel="Supplier">@pro.Supplier.Name</MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </Authorized>
</AuthorizeView>
@code {
    private string createInputName = "";
    private string createInputDescription = "";
    private int? createInputSupplierId;
    private double createInputWeight;
    private int createInputStock;

    private string updateInputName = "";
    private string updateInputDescription = "";
    private int? updateInputSupplierId;
    private double updateInputWeight;
    private int updateInputStock;
    private int updateId;

    private int deleteId;

    private List<Product> items = new();
    private List<Supplier> suppliers = new();

    private async Task AddToTable()
    {
        if (!string.IsNullOrWhiteSpace(createInputName) &&
            !string.IsNullOrWhiteSpace(createInputDescription) &&
            createInputSupplierId > 0 &&
            createInputWeight > 0.0 &&
            createInputStock > 0)
        {
            await Http.PostAsJsonAsync("https://localhost:7507/products", new
            {
                Name = createInputName,
                Description = createInputDescription,
                SupplierId = createInputSupplierId,
                Weight = createInputWeight,
                Stock = createInputStock
            }); // send post request to url with variables
        }
        createInputName = "";
        createInputDescription = "";
        createInputSupplierId = 0;
        createInputWeight = 0.0;
        createInputStock = 0;
        await ReturnAllInTable();
    }
    private async Task ReturnAllInTable()
    {
        items = await Http.GetFromJsonAsync<List<Product>>("https://localhost:7507/products"); // sends get request to url and turns data into list
    }
    private async Task LoadSuppliers()
    {
        suppliers = await Http.GetFromJsonAsync<List<Supplier>>("https://localhost:7507/suppliers");
    }
    private async Task UpdateRow()
    {
        if (
        !string.IsNullOrWhiteSpace(updateInputName) &&
        !string.IsNullOrWhiteSpace(updateInputDescription) &&
        updateInputSupplierId > 0 &&
        updateInputWeight > 0.0 &&
        updateInputStock > 0 &&
        updateId > 0)
        {
            await Http.PatchAsJsonAsync($"https://localhost:7507/products/{updateId}", new
            {
                Name = updateInputName,
                Description = updateInputDescription,
                SupplierId = updateInputSupplierId,
                Weight = updateInputWeight,
                Stock = updateInputStock
            }); // sends patch request to url with id and input
        }
        updateInputName = "";
        updateInputDescription = "";
        updateInputSupplierId = 0;
        updateInputWeight = 0.0;
        updateInputStock = 0;
        updateId = 0;
        await ReturnAllInTable();
    }
    private async Task DeleteRow()
    {
        if (deleteId > 0)
        {
            await Http.DeleteAsync($"https://localhost:7507/products/{deleteId}"); // sends delete request to url with id
        }
        deleteId = 0;
        await ReturnAllInTable();
    }
    protected override async Task OnInitializedAsync()
    {
        await ReturnAllInTable();
        await LoadSuppliers();
    }
}