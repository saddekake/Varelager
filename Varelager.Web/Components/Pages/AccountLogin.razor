@page "/"
@page "/AccountLogin"
@rendermode InteractiveServer

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-6">
    <MudPaper Class="pa-6" Elevation="3">
        <AuthorizeView>
            <Authorized Context="auth">
                <MudText Typo="Typo.h4" Class="mb-2">Signed in</MudText>
                <MudText Class="mb-4">Hello, @auth.User.Identity?.Name</MudText>

                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Href="/logout">
                        Logout
                    </MudButton>
                </MudStack>
            </Authorized>

            <NotAuthorized>
                <MudText Typo="Typo.h4" Class="mb-2">Login</MudText>
                <MudText Class="mb-4">Use Auth0 to sign in.</MudText>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Href="/login?returnUrl=/AccountCreation">
                    Login with Auth0
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudPaper>
</MudContainer>