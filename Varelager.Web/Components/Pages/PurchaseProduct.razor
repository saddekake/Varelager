@page "/PurchaseProduct"
@rendermode InteractiveServer
@inject HttpClient Http
@using Varelager.ApiService.Data

@*<select @bind="selectedValue">
    <option value="Product" selected>Product</option>
    <option value="Supplier">Supplier</option>
</select>
<br />
<br />*@

@* product *@
<div class="@(selectedValue == "Product" ? "" : "hidden")">
    <h3>Purchase Product</h3>
    <p>Product name: </p> <input type="text" placeholder="Name" @bind="ProductInputName" /> <br /><br />
    <p>Product amount: </p> <input type="number" placeholder="Amount" @bind="ProductInputAmount" /> <br /><br />
</div>

@* supplier *@
@*<div class="@(selectedValue == "Supplier" ? "" : "hidden")">
    <h3>Add Supplier</h3> <br />
    <p>Supplier name: </p> <input type="text" placeholder="Name" @bind="SupplierInputName" /> <br /><br />
    <p>Supplier phone: </p> <input type="text" placeholder="Phone" @bind="SupplierInputPhone" /> <br /><br />
    <p>Supplier email: </p> <input type="text" placeholder="Email" @bind="SupplierInputEmail" /> <br /><br />
