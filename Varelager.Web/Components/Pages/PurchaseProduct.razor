@page "/PurchaseProduct"
@rendermode InteractiveServer
@inject HttpClient Http
@using Varelager.ApiService.Data

<AuthorizeView Policy="WarehouseOnly">
    <NotAuthorized>
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
            Access denied
        </MudAlert>
    </NotAuthorized>
    <Authorized>

        <MudGrid Spacing="3">
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Purchase Product</MudText>

                    <MudStack Spacing="2">
                        <MudSelect T="int?"
                                   @bind-Value="ProductInputId"
                                   Label="Product"
                                   Placeholder="-- Select Product --"
                                   Variant="Variant.Outlined">
                            @foreach (var product in items)
                            {
                                <MudSelectItem Value="@((int?)product.Id)">
                                    @product.Name
                                </MudSelectItem>
                            }
                        </MudSelect>

                        <MudTextField T="int"
                                      @bind-Value="ProductInputAmount"
                                      Label="Amount"
                                      Variant="Variant.Outlined" />

                        <MudButton Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   OnClick="Confirm">
                            Purchase Product
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Products Table</MudText>

                    <MudTable Items="items" Dense="true" Hover="true" Striped="true">
                        <HeaderContent>
                            <MudTh>ID</MudTh>
                            <MudTh>Name</MudTh>
                            <MudTh>Description</MudTh>
                            <MudTh>Weight</MudTh>
                            <MudTh>Stock</MudTh>
                            <MudTh>Supplier</MudTh>
                        </HeaderContent>
                        <RowTemplate context="pro">
                            <MudTd DataLabel="ID">@pro.Id</MudTd>
                            <MudTd DataLabel="Name">@pro.Name</MudTd>
                            <MudTd DataLabel="Description">@pro.Description</MudTd>
                            <MudTd DataLabel="Weight">@pro.Weight</MudTd>
                            <MudTd DataLabel="Stock">@pro.Stock</MudTd>
                            <MudTd DataLabel="Supplier">@pro.Supplier.Name</MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </Authorized>
</AuthorizeView>

@code {
    private List<Product> items = new();
    private int? ProductInputId;
    private int ProductInputAmount;

    private async Task Confirm()
    {
        if (ProductInputId is null || ProductInputAmount < 1)
        {
            return;
        }

        var response = await Http.GetAsync($"https://localhost:7507/products/{ProductInputId}");

        if (!response.IsSuccessStatusCode)
        {
            Console.WriteLine("product not found");
            return;
        }

        var product = await response.Content.ReadFromJsonAsync<Product>();

        int productID = product.Id;
        int newStock = product.Stock + ProductInputAmount;

        await Http.PatchAsJsonAsync($"https://localhost:7507/products/{productID}", new
        {
            Stock = newStock
        });

        await Http.PostAsJsonAsync("https://localhost:7507/purchase_Log", new
        {
            ProductId = productID,
            AmountSold = ProductInputAmount,
        });

        ProductInputId = 0;
        ProductInputAmount = 0;

        await ReturnAllInTable();
    }

    private async Task ReturnAllInTable()
    {
        items = await Http.GetFromJsonAsync<List<Product>>("https://localhost:7507/products");
    }

    protected override async Task OnInitializedAsync()
    {
        await ReturnAllInTable();
    }
}