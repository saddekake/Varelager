@page "/Suppliers"
@rendermode InteractiveServer
@inject IHttpClientFactory Factory
@using Varelager.ApiService.Data

<AuthorizeView Policy="WarehouseOnly">
    <NotAuthorized>
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
            Access denied
        </MudAlert>
    </NotAuthorized>
    <Authorized>
        <MudText Typo="Typo.h3">Suppliers</MudText>

        @* ------------------------------------------ create *@
        <MudGrid Spacing="3">
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Create Supplier</MudText>

                    <MudStack Spacing="2">
                        <MudTextField T="string"
                                      @bind-Value="createInputName"
                                      Label="Name"
                                      Variant="Variant.Outlined" />

                        <MudTextField T="string"
                                      @bind-Value="createInputPhone"
                                      Label="Phone"
                                      Variant="Variant.Outlined" />

                        <MudTextField T="string"
                                      @bind-Value="createInputEmail"
                                      Label="Email"
                                      Variant="Variant.Outlined" />

                        <MudSelect T="int?"
                                   @bind-Value="createInputCountry"
                                   Label="Country"
                                   Placeholder="-- Select Country --"
                                   Variant="Variant.Outlined">

                            @foreach (var country in countries)
                            {
                                <MudSelectItem Value="@((int?)country.Id)">
                                    @country.Name
                                </MudSelectItem>
                            }
                        </MudSelect>

                        <MudButton Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   OnClick="AddToTable">
                            Add supplier
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudItem>
            @* ------------------------------------------ update *@
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Update Supplier</MudText>

                    <MudStack Spacing="2">
                        <MudTextField T="string"
                                      @bind-Value="updateInputName"
                                      Label="Name"
                                      Variant="Variant.Outlined" />

                        <MudTextField T="string"
                                      @bind-Value="updateInputPhone"
                                      Label="Phone"
                                      Variant="Variant.Outlined" />

                        <MudTextField T="string"
                                      @bind-Value="updateInputEmail"
                                      Label="Email"
                                      Variant="Variant.Outlined" />

                        <MudSelect T="int?"
                                   @bind-Value="updateInputCountry"
                                   Label="Country"
                                   Placeholder="-- Select Country --"
                                   Variant="Variant.Outlined">

                            @foreach (var country in countries)
                            {
                                <MudSelectItem Value="@((int?)country.Id)">
                                    @country.Name
                                </MudSelectItem>
                            }
                        </MudSelect>

                        <MudButton Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   OnClick="UpdateRow">
                            Update supplier
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudItem>
            @* ------------------------------------------ delete *@
            <MudItem xs="8" md="4">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Delete Supplier</MudText>
                    <MudInput T="int" @bind-Value="deleteId" placeholder="ID of deleting row" />
                    <MudButton Color="Color.Primary" Variant=Variant.Filled" OnClick="DeleteRow">Delete</MudButton>
                </MudPaper>
            </MudItem>

            @* table *@
            <MudItem xs="12">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Suppliers Table</MudText>

                    <MudTable Items="items" Dense="true" Hover="true" Striped="true">
                        <HeaderContent>
                            <MudTh>ID</MudTh>
                            <MudTh>Name</MudTh>
                            <MudTh>Phone</MudTh>
                            <MudTh>Email</MudTh>
                            <MudTh>Country</MudTh>
                        </HeaderContent>
                        <RowTemplate context="sup">
                            <MudTd DataLabel="ID">@sup.Id</MudTd>
                            <MudTd DataLabel="Name">@sup.Name</MudTd>
                            <MudTd DataLabel="Phone">@sup.Phone</MudTd>
                            <MudTd DataLabel="Email">@sup.Email</MudTd>
                            <MudTd DataLabel="Country">@sup.Country.Name</MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </Authorized>
</AuthorizeView>
@code {
    private HttpClient Api => Factory.CreateClient("Api");

    private string createInputName = "";
    private string createInputPhone = "";
    private string createInputEmail = "";
    private int? createInputCountry;

    private string updateInputName = "";
    private string updateInputPhone = "";
    private string updateInputEmail = "";
    private int? updateInputCountry;
    private int updateId;

    private int deleteId;

    private List<Supplier> items = new();
    private List<Country> countries = new();

    private async Task AddToTable()
    {
        if (!string.IsNullOrWhiteSpace(createInputName) &&
            !string.IsNullOrWhiteSpace(createInputPhone) &&
            !string.IsNullOrWhiteSpace(createInputEmail) &&
            createInputCountry.HasValue)
        {
            await Api.PostAsJsonAsync("https://localhost:7507/suppliers", new
            {
                Name = createInputName,
                Phone = createInputPhone,
                Email = createInputEmail,
                CountryId = createInputCountry,
            }); // send post request to url with variables
        }
        createInputName = "";
        createInputPhone = "";
        createInputEmail = "";
        createInputCountry = null;
        await ReturnAllInTable();
    }
    private async Task ReturnAllInTable()
    {
        items = await Api.GetFromJsonAsync<List<Supplier>>("https://localhost:7507/suppliers"); // sends get request to url and turns data into list
    }

    private async Task LoadCountries()
    {
        countries = await Api.GetFromJsonAsync<List<Country>>(
            "https://localhost:7507/countries"
        ) ?? new();

        await InvokeAsync(StateHasChanged);
    }

    private async Task UpdateRow()
    {
        if (
        !string.IsNullOrWhiteSpace(updateInputName) &&
        !string.IsNullOrWhiteSpace(updateInputPhone) &&
        !string.IsNullOrWhiteSpace(updateInputEmail) &&
        updateInputCountry > 0 &&
        updateId > 0)
        {
            await Api.PatchAsJsonAsync($"https://localhost:7507/suppliers/{updateId}", new
            {
                Name = updateInputName,
                Phone = updateInputPhone,
                Email = updateInputEmail,
                CountryId = updateInputCountry,
            }); // sends patch request to url with id and input
        }
        updateInputName = "";
        updateInputPhone = "";
        updateInputEmail = "";
        updateInputCountry = 0;
        updateId = 0;
        await ReturnAllInTable();
    }
    private async Task DeleteRow()
    {
        if (deleteId > 0)
        {
            await Api.DeleteAsync($"https://localhost:7507/suppliers/{deleteId}"); // sends delete request to url with id
        }
        deleteId = 0;
        await ReturnAllInTable();
    }
    protected override async Task OnInitializedAsync()
    {
        await LoadCountries();
        await ReturnAllInTable();
    }
}