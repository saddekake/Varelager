@page "/Log"
@rendermode InteractiveServer
@inject HttpClient Http
@using Varelager.ApiService.Data
    <AuthorizeView Policy="AdminOnly">
        <NotAuthorized>
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
                Access denied
            </MudAlert>
        </NotAuthorized>
        <Authorized>
                <MudText Typo="Typo.h4" Class="mb-4">Log</MudText>

    <!-- purchase table -->
    <MudPaper Class="pa-4 mb-6">
        <MudText Typo="Typo.h6" Class="mb-2">Purchases</MudText>

        <MudTable Items="purchases" Dense="true" Hover="true" Striped="true">
            <HeaderContent>
                <MudTh>Product Name</MudTh>
                <MudTh>Amount Bought</MudTh>
                <MudTh>Account Responsible</MudTh>
            </HeaderContent>

                <RowTemplate Context="purchase">
                    <MudTd>@purchase.Product.Name</MudTd>
                    <MudTd>@purchase.AmountSold</MudTd>
                    <MudTd>@purchase.Account.Name</MudTd>
                </RowTemplate>
        </MudTable>
    </MudPaper>

    <!-- sales table -->
    <MudPaper Class="pa-4">
        <MudText Typo="Typo.h6" Class="mb-2">Sales</MudText>

        <MudTable Items="sales" Dense="true" Hover="true" Striped="true">
            <HeaderContent>
                <MudTh>Product Name</MudTh>
                <MudTh>Amount Sold</MudTh>
                <MudTh>Customer First Name</MudTh>
                <MudTh>Customer Last Name</MudTh>
                <MudTh>Account Name</MudTh>
            </HeaderContent>

                <RowTemplate Context="sale">
                    <MudTd>@sale.Product.Name</MudTd>
                    <MudTd>@sale.AmountSold</MudTd>
                    <MudTd>@sale.Customer.FName</MudTd>
                    <MudTd>@sale.Customer.LName</MudTd>
                    <MudTd>@sale.Account.Name</MudTd>
                </RowTemplate>
        </MudTable>
    </MudPaper>
        </Authorized>
    </AuthorizeView>

@code {
    private List<Purchase_Log> purchases = new();
    private List<Sale_Log> sales = new();

    private async Task ReturnAllInTable()
    {
        try { purchases = await Http.GetFromJsonAsync<List<Purchase_Log>>("https://localhost:7507/purchase_Log"); }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized) { Console.WriteLine("Unauthorized Get request to purchase_Log"); }
    sales = await Http.GetFromJsonAsync<List<Sale_Log>>("https://localhost:7507/sale_Log");
    }

    protected override async Task OnInitializedAsync()
    {
        await ReturnAllInTable();
    }
}