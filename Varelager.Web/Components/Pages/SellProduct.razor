@page "/SellProduct"
@rendermode InteractiveServer
@inject HttpClient Http
@using Varelager.ApiService.Data

<AuthorizeView Policy="SalesOnly">
    <NotAuthorized>
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
            Access denied
        </MudAlert>
    </NotAuthorized>
    <Authorized>
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
            @ErrorMessage
        </MudAlert>
        <MudText Typo="Typo.h3">Sell Product</MudText>
        <MudGrid Spacing="3">
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Sell Product</MudText>

                    <MudStack Spacing="2">
                        <MudSelect T="int?"
                                   @bind-Value="ProductInputId"
                                   Label="Product"
                                   Placeholder="-- Select Product --"
                                   Variant="Variant.Outlined">
                            @foreach (var product in items)
                            {
                                <MudSelectItem Value="@((int?)product.Id)">
                                    @product.Name
                                </MudSelectItem>
                            }
                        </MudSelect>

                        <MudSelect T="int?"
                                   @bind-Value="ProductInputCustomer"
                                   Label="Customer"
                                   Placeholder="-- Select Customer --"
                                   Variant="Variant.Outlined">
                            @foreach (var customer in customers)
                            {
                                <MudSelectItem Value="@((int?)customer.Id)">
                                    @customer.FName @customer.LName
                                </MudSelectItem>
                            }
                        </MudSelect>

                        <MudTextField T="int"
                                      @bind-Value="ProductInputAmount"
                                      Label="Amount"
                                      Variant="Variant.Outlined" />

                        <MudButton Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   OnClick="Confirm">
                            Sell Product
                        </MudButton>

                        <MudText Typo="Typo.body1">
                            <span style="opacity:0.7;">Delivery cost:</span>
                            @DeliveryCost
                        </MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>

            @* table *@
            <MudItem xs="12">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3">Products Table</MudText>

                    <MudTable Items="items" Dense="true" Hover="true" Striped="true">
                        <HeaderContent>
                            <MudTh>ID</MudTh>
                            <MudTh>Name</MudTh>
                            <MudTh>Description</MudTh>
                            <MudTh>Weight</MudTh>
                            <MudTh>Stock</MudTh>
                            <MudTh>Supplier</MudTh>
                        </HeaderContent>
                        <RowTemplate context="pro">
                            <MudTd DataLabel="ID">@pro.Id</MudTd>
                            <MudTd DataLabel="Name">@pro.Name</MudTd>
                            <MudTd DataLabel="Description">@pro.Description</MudTd>
                            <MudTd DataLabel="Weight">@pro.Weight</MudTd>
                            <MudTd DataLabel="Stock">@pro.Stock</MudTd>
                            <MudTd DataLabel="Supplier">@pro.Supplier.Name</MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </Authorized>
</AuthorizeView>
@code {
    private int? ProductInputId;
    private int ProductInputAmount;
    private int? ProductInputCustomer; // for the sales log page
    private double DeliveryCost;
    private List<Product> items = new();
    private List<Customer> customers = new();
    private string? ErrorMessage;

    private async Task ReturnAllInTable()
    {
        items = await Http.GetFromJsonAsync<List<Product>>("https://localhost:7507/products"); // sends get request to url and turns data into list
    }
    private async Task LoadCustomers()
    {
        customers = await Http.GetFromJsonAsync<List<Customer>>("https://localhost:7507/customers");
    }
    private void CalculateDelivery(double Weight, int Distance)
    {
        DeliveryCost = ((Weight * 0.1) * ProductInputAmount) * Distance;
    }

    private async Task Confirm()
    {
        ErrorMessage = null;

        try
        {
            if (ProductInputId is null || ProductInputAmount < 1 || ProductInputCustomer is null)
            {
                ErrorMessage = "Select a product, customer, and amount.";
                return;
            }

            var productresponse = await Http.GetAsync($"https://localhost:7507/products/{ProductInputId}");

            if (!productresponse.IsSuccessStatusCode)
            {
                ErrorMessage = $"{(int)productresponse.StatusCode} {productresponse.ReasonPhrase}";
                return;
            }

            var product = await productresponse.Content.ReadFromJsonAsync<Product>();
            if (product is null)
            {
                ErrorMessage = "Could not read product data.";
                return;
            }

            var customer = customers.FirstOrDefault(c => c.Id == ProductInputCustomer.Value);
            if (customer == null)
            {
                ErrorMessage = "Customer not found.";
                return;
            }

            if (customer.Country == null)
            {
                ErrorMessage = "Customer country was not loaded.";
                return;
            }

            int productID = product.Id;
            int newStock = product.Stock - ProductInputAmount;

            CalculateDelivery(product.Weight, customer.Country.Distance);

            await Http.PatchAsJsonAsync($"https://localhost:7507/products/{productID}", new
            {
                Stock = newStock
            });

            await Http.PostAsJsonAsync("https://localhost:7507/sale_Log", new
            {
                ProductId = productID,
                AmountSold = ProductInputAmount,
                CustomerId = ProductInputCustomer,
            });

            ProductInputAmount = 0;
            ProductInputCustomer = null;
            ProductInputId = null;
            await ReturnAllInTable();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await ReturnAllInTable();
        await LoadCustomers();
    }
}